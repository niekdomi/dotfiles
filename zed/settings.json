//    - No TOC
//    - In-Editor PDF-Viewer (needed?)
//   - TODO-comments
//   - Bugs:
//     - Java go to definition not working
//     - C# go to definition results in empty file
// - VIM:
//   - Block comments with gbc not available
//   - flash.nvim
//   - Scroll percentage missing
//   - / search should use smart-case so writing in capital is case-sensitive
//   - Do not need to press enter to accept completion
//   - Don't select the first suggestion when pressing enter
//   - / search should not remove highlighting when pressing esc (only when :nohl)
//   - Show live changes when changing regex with %s  https://github.com/zed-industries/zed/issues/4411
//   - Vim mode in rename pop-up
//   - % navigation (bash, lua, etc.)
//   - scrolling shouldn't exceed last line, only with zz e.g.
//   - Which-key like window
//   - Insert from Register-overview when pressing "
// - Editor:
//   - Ligatures buggy
//   - Smooth-scroll missing
//   - Strikethrough text
//   - Choose specific font type e.g., italic, not just the family
//   - Icons in auto completion
//   - Test explorer
//   - Icons in outline
//   - Cursor animation
//   - Change editor size with ctrl+scroll
//   - Show amount of copilot options e.g. 2/7
//   - Render markdown like obsidian (would be nice for text thread)
//   - Proper CMake implementation (for nice c++ development)
//   - HTML in Editor preview (Web page preview)
//   - Python notebook
//   - PDF Viewer
//   - Better outline
//   - Undotree
//   - Revert shitty completion ui/bindings
//   - Inverted cursor color
//   - Ligatures under cursor not rendered correctly
//   - autocompletion: Better UI
//   - Telescope like window
// - Terminal:
//   - Italic text
//   - Ligatures
//   - Starship prompt buggy
//   - Render TUI border correctly
//   - Image preview

{
  // Updating with package manager
  "auto_update": false,

  // Auto-install extensions
  "auto_install_extensions": {
    "basher": true,
    "catppuccin": true,
    "catppuccin-icons": true,
    "cspell": false, // Should use codebook at a certain point
    "golangci-lint": true,
    "html": true,
    "latex": true,
    "lua": true,
    "toml": true,
    "xml": true,
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ Telemetry                                                │
  // ╰──────────────────────────────────────────────────────────╯
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ UI                                                       │
  // ╰──────────────────────────────────────────────────────────╯
  "collaboration_panel": {
    "button": false,
  },
  "git_panel": {
    "tree_view": true,
  },
  "gutter": {
    "folds": false,
    "min_line_number_digits": 3,
    // "runnables": false
  },
  "notification_panel": {
    "button": false,
  },
  "outline_panel": {
    "button": false,
    "dock": "right",
  },
  "project_panel": {
    "folder_icons": false,
    "hide_root": true,
    "indent_size": 25,
    "sticky_scroll": false,
  },
  "tab_bar": {
    "show": true,
    "show_nav_history_buttons": false,
  },
  "search": {
    "button": true,
  },
  "tabs": {
    "git_status": true,
    "file_icons": true,
  },
  "title_bar": {
    "show_branch_icon": true,
  },
  "toolbar": {
    "breadcrumbs": false,
    "quick_actions": false,
  },
  "zoomed_padding": false,

  // ╭──────────────────────────────────────────────────────────╮
  // │ Editor                                                   │
  // ╰──────────────────────────────────────────────────────────╯
  "always_treat_brackets_as_autoclosed": true,
  "auto_signature_help": false,
  "diagnostics": {
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 2,
      "max_severity": "warning",
    },
  },
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 1000,
      "show_commit_summary": true,
    },
  },
  "hide_mouse": "on_typing_and_movement",
  "inline_code_actions": false,
  "middle_click_paste": false,
  "vertical_scroll_margin": 0,
  "beam_jump": true,

  // ╭──────────────────────────────────────────────────────────╮
  // │ Vim                                                      │
  // ╰──────────────────────────────────────────────────────────╯
  "vim_mode": true,
  "cursor_blink": false,
  "relative_line_numbers": "enabled",
  // "scroll_beyond_last_line": "off",
  "scrollbar": {
    "show": "never",
  },
  "vim": {
    "highlight_on_yank_duration": 0,
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ Font                                                     │
  // ╰──────────────────────────────────────────────────────────╯
  "ui_font_size": 15,
  "buffer_font_size": 14.0,
  "buffer_line_height": {
    "custom": 1.4,
  },
  "buffer_font_weight": 350.0,

  "buffer_font_family": ".ZedMono",
  "buffer_font_features": {
    "ss19": true,
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ Theme                                                    │
  // ╰──────────────────────────────────────────────────────────╯
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha",
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ Assistant                                                │
  // ╰──────────────────────────────────────────────────────────╯
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "grok-code-fast-1",
    },
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.5",
    },
    "always_allow_tool_actions": true,
    "default_profile": "write",
    "model_parameters": [],
    "use_modifier_to_send": true,
  },
  "show_edit_predictions": true,
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "edit_predictions": {
    "mode": "eager",
  },
  "disable_ai": false,

  // ╭──────────────────────────────────────────────────────────╮
  // │ Terminal                                                 │
  // ╰──────────────────────────────────────────────────────────╯
  "terminal": {
    "dock": "bottom",
    "line_height": "standard",
    "toolbar": {
      "breadcrumbs": false,
    },
    "font_family": "CaskaydiaCove Nerd Font Mono",
    "font_features": {
      "ss19": true,
    },
    "font_size": 14,
    "font_weight": 360,
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ LSP                                                      │
  // ╰──────────────────────────────────────────────────────────╯
  "lsp": {
    "golangci-lint": {
      "initialization_options": {
        "command": [
          "golangci-lint",
          "run",
          "--output.json.path=stdout",
          "--issues-exit-code=1",
          "--show-stats=false",
          "--fix",
          "--enable-only=wsl_v5",
        ],
      },
    },
    "gopls": {
      "initialization_options": {
        "analyses": {
          "unusedparams": true,
        },
        "gofumpt": true,
        "staticcheck": true,
        "usePlaceholders": true,
        "hints": {
          "assignVariableTypes": false,
          "compositeLiteralFields": false,
          "compositeLiteralTypes": false,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
    "texlab": {
      "settings": {
        "texlab": {
          "build": {
            "onSave": false,
            "forwardSearchAfter": true,
            // "executable": "tectonic",
            // "args": ["-Z", "shell-escape", "%f"]
            "executable": "pdflatex",
            "args": ["--shell-escape", "%f"],
          },
        },
        "forwardSearch": {
          "executable": "zathura",
          "args": [
            "--synctex-forward",
            "%l:1:%f",
            "-x",
            "zed %%{input}:%%{line}",
            "%p",
          ],
        },
      },
    },
  },

  // ╭──────────────────────────────────────────────────────────╮
  // │ Language config                                          │
  // ╰──────────────────────────────────────────────────────────╯
  "languages": {
    "C": {
      "format_on_save": "on",
    },
    "C++": {
      "format_on_save": "on",
    },
    "CSharp": {
      "formatter": {
        "external": {
          "command": "csharpier",
          "arguments": ["format"],
        },
      },
    },
    "Go": {
      "language_servers": ["gopls", "golangci-lint"],
    },
    "Markdown": {
      "format_on_save": "on",
    },
    "LaTeX": {
      "formatter": {
        "external": {
          "command": "latexindent",
          "arguments": ["-m", "-rv", "-l"],
        },
      },
    },
    "Lua": {
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["--stdin-filepath", "{buffer_path}", "-"],
        },
      },
    },
    "Python": {
      "language_servers": ["pyright", "ruff"],
      "formatter": [
        { "code_action": "source.organizeImports.ruff" },
        { "code_action": "source.fixAll.ruff" },
        {
          "language_server": {
            "name": "ruff",
          },
        },
      ],
    },
  },

  // Italic fix
  "experimental.theme_overrides": {
    "border.variant": "#00000000", // Remove border color
    "syntax": {
      "attribute": {
        "font_style": "italic",
      },
      "boolean": {
        "font_style": "italic",
      },
      "comment": {
        "font_style": "italic",
      },
      "comment.doc": {
        "font_style": "italic",
      },
      "constant": {
        "font_style": "italic",
      },
      "constructor": {
        "font_style": "italic",
      },
      "embedded": {
        "font_style": "italic",
      },
      "emphasis": {
        "font_style": "italic",
      },
      "emphasis.strong": {
        "font_style": "italic",
      },
      "enum": {
        "font_style": "italic",
      },
      "function": {
        "font_style": "italic",
      },
      "hint": {
        "font_style": "italic",
      },
      "keyword": {
        "font_style": "italic",
      },
      "label": {
        "font_style": "italic",
      },
      "link_text": {
        "font_style": "italic",
      },
      "link_uri": {
        "font_style": "italic",
      },
      "number": {
        "font_style": "italic",
      },
      "operator": {
        "font_style": "italic",
      },
      "predictive": {
        "font_style": "italic",
      },
      "preproc": {
        "font_style": "italic",
      },
      "primary": {
        "font_style": "italic",
      },
      "property": {
        "font_style": "italic",
      },
      "punctuation": {
        "font_style": "italic",
      },
      "punctuation.bracket": {
        "font_style": "italic",
      },
      "punctuation.delimiter": {
        "font_style": "italic",
      },
      "punctuation.list_marker": {
        "font_style": "italic",
      },
      "punctuation.special": {
        "font_style": "italic",
      },
      "string": {
        "font_style": "italic",
      },
      "string.escape": {
        "font_style": "italic",
      },
      "string.regex": {
        "font_style": "italic",
      },
      "string.special": {
        "font_style": "italic",
      },
      "string.special.symbol": {
        "font_style": "italic",
      },
      "tag": {
        "font_style": "italic",
      },
      "text.literal": {
        "font_style": "italic",
      },
      "title": {
        "font_style": "italic",
      },
      "type": {
        "font_style": "italic",
      },
      "variable": {
        "font_style": "italic",
      },
      "variable.special": {
        "font_style": "italic",
      },
      "variant": {
        "font_style": "italic",
      },
    },
  },
}
