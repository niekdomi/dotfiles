# Theme
theme = dark:Catppuccin Mocha, light:Catppuccin Latte

### Font
font-size=11

font-family = "CaskaydiaCove Nerd Font"
font-style = "Light Italic"
font-style-italic = "Light italic"
font-style-bold = "italic"

font-feature = ss02, ss19
# Use 'ss01' for fancy italic style


# Cursor
cursor-color = cell-foreground
selection-foreground = cell-foreground

# Mouse
mouse-scroll-multiplier = 0.5
mouse-hide-while-typing

# Window
unfocused-split-opacity = 1
window-height = 28
window-width = 90

# Cell
adjust-cell-height = 15%
adjust-underline-position = 15%

# Don't use protection ;-)
clipboard-paste-protection = false
confirm-close-surface = false

# Miscellaneous
gtk-toolbar-style = flat
custom-shader = cursor_sweep.glsl

### Keybinds
keybind = ctrl+shift+r=reload_config
keybind = ctrl+shift+f2=open_config
keybind = performable:ctrl+l=clear_screen
keybind = f12=toggle_window_decorations
keybind = ctrl+shift+w=close_surface
keybind = ctrl+shift+.=toggle_command_palette

# Font size
keybind = ctrl+shift+a=increase_font_size:0.5
keybind = ctrl+shift+x=decrease_font_size:0.5

# Tab
keybind = ctrl+shift+p=next_tab
keybind = ctrl+shift+n=previous_tab
keybind = ctrl+shift+enter=toggle_tab_overview

# Window (splits)
keybind = ctrl+shift+k=goto_split:top
keybind = ctrl+shift+j=goto_split:bottom
keybind = ctrl+shift+h=goto_split:left
keybind = ctrl+shift+l=goto_split:right

keybind = ctrl+shift+o=new_window

keybind = shift+alt+k=new_split:up
keybind = shift+alt+j=new_split:down
keybind = shift+alt+h=new_split:left
keybind = shift+alt+l=new_split:right

# Buffer (scrolling)
keybind = ctrl+shift+$=scroll_to_bottom
keybind = ctrl+shift+^=scroll_to_top

keybind = ctrl+shift+u=scroll_page_lines:-1
keybind = ctrl+shift+d=scroll_page_lines:1

keybind = ctrl+shift+b=scroll_page_fractional:-0.5
keybind = ctrl+shift+f=scroll_page_fractional:0.5

# Unbined other keybinds
keybind = ctrl+,=unbind
keybind = ctrl+enter=unbind
